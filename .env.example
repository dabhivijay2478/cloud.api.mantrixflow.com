# ============================================
# Server Configuration
# ============================================
PORT=8000
NODE_ENV=development

# ============================================
# API URLs
# ============================================
# Production API URL (used in Swagger documentation)
API_URL=https://api.mantrixflow.com

# Development server URL (used in Swagger documentation)
DEV_SERVER_URL=http://localhost:8000

# ============================================
# Frontend URLs & CORS Configuration
# ============================================
# Primary frontend URL (used for CORS and invite links)
FRONTEND_URL=http://localhost:3000

# Next.js public app URL (alternative frontend URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed origins for CORS
# Example: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# Default development origin (used when origin is undefined in development)
DEFAULT_DEV_ORIGIN=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mantrixflow

# Individual database connection parameters (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=mantrixflow

# ============================================
# Supabase Configuration
# ============================================
# Supabase project URL
SUPABASE_URL=your_supabase_project_url

# Supabase anonymous key (public key)
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (private key, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase webhook secret (for verifying webhook requests)
SUPABASE_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# Redis Configuration (for BullMQ)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ============================================
# Encryption Configuration
# ============================================
# Encryption key for encrypting database credentials (must be 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key
