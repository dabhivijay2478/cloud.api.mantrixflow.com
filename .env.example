# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_DIRECT_URL=postgresql://user:pass@host:5432/dbname

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ETL Server (new PyAirbyte ETL)
# Required for connectors, discover, preview, sync. When unreachable, connectors use fallback registry.
ETL_SERVICE_URL=https://mantrixflow-etl.fly.dev
# Local dev: run apps/new-etl (uvicorn) and set:
# ETL_SERVICE_URL=http://localhost:8000
# Or legacy:
# ETL_PYTHON_SERVICE_URL=http://localhost:8001
# ETL uses Supabase JWT — pass SUPABASE_SERVICE_ROLE_KEY as Bearer token

# Internal API (for ETL callback)
INTERNAL_API_URL=https://cloud.api.mantrixflow.com
INTERNAL_TOKEN=your-strong-secret-matches-etl-callback

# CORS
ALLOWED_ORIGINS=https://app.mantrixflow.com,http://localhost:3000
