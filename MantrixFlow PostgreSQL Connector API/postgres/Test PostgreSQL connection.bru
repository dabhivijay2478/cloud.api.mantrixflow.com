meta {
  name: Test PostgreSQL connection
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/connectors/postgres/test-connection
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "host": "localhost",
    "port": 5432,
    "database": "mydb",
    "username": "postgres",
    "password": "password123",
    "ssl": null,
    "sshTunnel": null,
    "connectionTimeout": 30000,
    "queryTimeout": 60000,
    "poolSize": 5
  }
}

settings {
  encodeUrl: true
}

docs {
  Test a PostgreSQL connection without saving it. Validates credentials and connectivity.
}

example {
  name: 200 Connection test successful
  
  request: {
    url: {{baseUrl}}/api/connectors/postgres/test-connection
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
        "host": "localhost",
        "port": 5432,
        "database": "mydb",
        "username": "postgres",
        "password": "password123",
        "ssl": null,
        "sshTunnel": null,
        "connectionTimeout": 30000,
        "queryTimeout": 60000,
        "poolSize": 5
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
          "success": true,
          "error": "string",
          "version": "PostgreSQL 14.5",
          "responseTimeMs": 45
        }
      '''
    }
  }
}
