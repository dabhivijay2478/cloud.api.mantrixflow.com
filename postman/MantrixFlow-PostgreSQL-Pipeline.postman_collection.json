                {
                    "name": "Update Pipeline",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/connectors/postgres/pipelines/{{pipelineId}}?orgId={{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "connectors",
                                "postgres",
                                "pipelines",
                                "{{pipelineId}}"
                            ],
                            "query": [
                                {
                                    "key": "orgId",
                                    "value": "{{orgId}}"
                                }
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Updated Pipeline Name\",\n  \"description\": \"Updated description\",\n  \"syncFrequency\": \"1hour\"\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Delete Pipeline",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/connectors/postgres/pipelines/{{pipelineId}}?orgId={{orgId}}&dropTable=false",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "connectors",
                                "postgres",
                                "pipelines",
                                "{{pipelineId}}"
                            ],
                            "query": [
                                {
                                    "key": "orgId",
                                    "value": "{{orgId}}"
                                },
                                {
                                    "key": "dropTable",
                                    "value": "false",
                                    "description": "Set to true to also drop the destination table"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
