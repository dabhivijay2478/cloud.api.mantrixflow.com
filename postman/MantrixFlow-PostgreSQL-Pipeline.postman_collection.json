{
    "info": {
        "name": "MantrixFlow - PostgreSQL Pipeline API",
        "description": "Complete API collection for PostgreSQL bidirectional data pipelines. Includes all 15 endpoints for pipeline management, execution, and monitoring.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "version": "1.0.0"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "orgId",
            "value": "your-org-id-here",
            "type": "string"
        },
        {
            "key": "userId",
            "value": "your-user-id-here",
            "type": "string"
        },
        {
            "key": "pipelineId",
            "value": "",
            "type": "string"
        },
        {
            "key": "runId",
            "value": "",
            "type": "string"
        },
        {
            "key": "sourceConnectionId",
            "value": "your-source-connection-id",
            "type": "string"
        },
        {
            "key": "destinationConnectionId",
            "value": "your-destination-connection-id",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Pipeline Management",
            "item": [
                {
                    "name": "Create Pipeline",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/connectors/postgres/pipelines",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "connectors",
                                "postgres",
                                "pipelines"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Orders Replication Pipeline\",\n  \"description\": \"Sync orders from production to analytics database\",\n  \"sourceType\": \"postgres\",\n  \"sourceConnectionId\": \"{{sourceConnectionId}}\",\n  \"sourceSchema\": \"public\",\n  \"sourceTable\": \"orders\",\n  \"destinationConnectionId\": \"{{destinationConnectionId}}\",\n  \"destinationSchema\": \"analytics\",\n  \"destinationTable\": \"orders_replica\",\n  \"writeMode\": \"upsert\",\n  \"upsertKey\": [\"id\"],\n  \"syncMode\": \"incremental\",\n  \"incrementalColumn\": \"updated_at\",\n  \"syncFrequency\": \"15min\",\n  \"columnMappings\": [\n    {\n      \"sourceColumn\": \"id\",\n      \"destinationColumn\": \"id\",\n      \"dataType\": \"UUID\",\n      \"nullable\": false,\n      \"isPrimaryKey\": true\n    },\n    {\n      \"sourceColumn\": \"customer_id\",\n      \"destinationColumn\": \"customer_id\",\n      \"dataType\": \"UUID\",\n      \"nullable\": false\n    },\n    {\n      \"sourceColumn\": \"total\",\n      \"destinationColumn\": \"total_amount\",\n      \"dataType\": \"NUMERIC\",\n      \"nullable\": false\n    },\n    {\n      \"sourceColumn\": \"status\",\n      \"destinationColumn\": \"order_status\",\n      \"dataType\": \"VARCHAR(50)\",\n      \"nullable\": false\n    },\n    {\n      \"sourceColumn\": \"created_at\",\n      \"destinationColumn\": \"created_at\",\n      \"dataType\": \"TIMESTAMPTZ\",\n      \"nullable\": false\n    },\n    {\n      \"sourceColumn\": \"updated_at\",\n      \"destinationColumn\": \"updated_at\",\n      \"dataType\": \"TIMESTAMPTZ\",\n      \"nullable\": false\n    }\n  ]\n}"
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    const response = pm.response.json();",
                                    "    pm.collectionVariables.set('pipelineId', response.data.id);",
                                    "    pm.test('Pipeline created successfully', () => {",
                                    "        pm.expect(response.success).to.be.true;",
                                    "    });",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "List Pipelines",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/connectors/postgres/pipelines?orgId={{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "connectors",
                                "postgres",
                                "pipelines"
                            ],
                            "query": [
                                {
                                    "key": "orgId",
                                    "value": "{{orgId}}"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Pipeline Details",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/connectors/postgres/pipelines/{{pipelineId}}?orgId={{orgId}}",
