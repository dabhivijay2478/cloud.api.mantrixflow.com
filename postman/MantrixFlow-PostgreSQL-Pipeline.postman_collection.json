                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Users Full Sync\",\n  \"description\": \"Full sync of users table\",\n  \"sourceType\": \"postgres\",\n  \"sourceConnectionId\": \"{{sourceConnectionId}}\",\n  \"sourceSchema\": \"public\",\n  \"sourceTable\": \"users\",\n  \"destinationConnectionId\": \"{{destinationConnectionId}}\",\n  \"destinationSchema\": \"backup\",\n  \"destinationTable\": \"users_backup\",\n  \"writeMode\": \"replace\",\n  \"syncMode\": \"full\",\n  \"syncFrequency\": \"24hours\"\n}"
                        }
                    },
                    "response": []
