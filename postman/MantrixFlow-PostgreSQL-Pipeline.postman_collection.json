                            "raw": "{\n  \"name\": \"User Activity Summary\",\n  \"description\": \"Aggregate user activity data\",\n  \"sourceType\": \"postgres\",\n  \"sourceConnectionId\": \"{{sourceConnectionId}}\",\n  \"sourceQuery\": \"SELECT user_id, COUNT(*) as activity_count, MAX(created_at) as last_activity FROM user_events WHERE created_at > NOW() - INTERVAL '7 days' GROUP BY user_id\",\n  \"destinationConnectionId\": \"{{destinationConnectionId}}\",\n  \"destinationSchema\": \"analytics\",\n  \"destinationTable\": \"user_activity_weekly\",\n  \"writeMode\": \"replace\",\n  \"syncMode\": \"full\",\n  \"syncFrequency\": \"24hours\"\n}"
