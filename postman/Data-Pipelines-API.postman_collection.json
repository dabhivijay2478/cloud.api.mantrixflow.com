								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/resume",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"resume"
							]
						},
						"description": "Resume a paused pipeline."
					},
					"response": []
				}
			],
			"description": "Control pipeline execution state"
		},
		{
			"name": "Pipeline Configuration",
			"item": [
				{
					"name": "Auto-map Columns",
