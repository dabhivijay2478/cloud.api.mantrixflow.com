						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/stats",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"stats"
							]
						},
						"description": "Retrieve aggregated statistics for a pipeline."
					},
					"response": []
