{
	"info": {
		"_postman_id": "data-pipelines-v1",
		"name": "Data Pipelines API",
		"description": "Complete API collection for data pipeline management including creation, execution, monitoring, and lifecycle management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "mantrixflow"
	},
	"item": [
		{
			"name": "Pipeline Management",
			"item": [
				{
					"name": "Create Pipeline",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response contains pipeline ID\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('data');",
									"    pm.expect(jsonData.data).to.have.property('id');",
									"    pm.environment.set(\"pipeline_id\", jsonData.data.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Users Pipeline\",\n  \"description\": \"Sync users table from source to destination\",\n  \"sourceType\": \"postgres\",\n  \"sourceConnectionId\": \"{{source_connection_id}}\",\n  \"sourceSchema\": \"public\",\n  \"sourceTable\": \"users\",\n  \"destinationConnectionId\": \"{{destination_connection_id}}\",\n  \"destinationSchema\": \"public\",\n  \"destinationTable\": \"users_synced\",\n  \"writeMode\": \"append\",\n  \"syncMode\": \"full\",\n  \"syncFrequency\": \"manual\",\n  \"columnMappings\": [\n    {\n      \"sourceColumn\": \"id\",\n      \"destinationColumn\": \"id\",\n      \"dataType\": \"uuid\",\n      \"nullable\": false,\n      \"isPrimaryKey\": true\n    },\n    {\n      \"sourceColumn\": \"name\",\n      \"destinationColumn\": \"name\",\n      \"dataType\": \"varchar\",\n      \"nullable\": false,\n      \"maxLength\": 255\n    },\n    {\n      \"sourceColumn\": \"email\",\n      \"destinationColumn\": \"email\",\n      \"dataType\": \"varchar\",\n      \"nullable\": false,\n      \"maxLength\": 255\n    }\n  ],\n  \"transformations\": []\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/data-pipelines",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines"
							]
						},
						"description": "Create a new data pipeline to sync data from a source to PostgreSQL destination."
					},
					"response": []
				},
				{
					"name": "List Pipelines",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines?orgId={{org_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines"
							],
							"query": [
								{
									"key": "orgId",
									"value": "{{org_id}}"
								}
							]
						},
						"description": "Get all data pipelines for the organization."
					},
					"response": []
				},
				{
					"name": "Get Pipeline by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}?orgId={{org_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}"
							],
							"query": [
								{
									"key": "orgId",
									"value": "{{org_id}}"
								}
							]
						},
						"description": "Retrieve detailed information about a specific pipeline."
					},
					"response": []
				},
				{
					"name": "Update Pipeline",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Pipeline Name\",\n  \"description\": \"Updated description\",\n  \"syncFrequency\": \"1hour\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}?orgId={{org_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}"
							],
							"query": [
								{
									"key": "orgId",
									"value": "{{org_id}}"
								}
							]
						},
						"description": "Update pipeline configuration."
					},
					"response": []
				},
				{
					"name": "Delete Pipeline",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}?dropTable=false&orgId={{org_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}"
							],
							"query": [
								{
									"key": "dropTable",
									"value": "false"
								},
								{
									"key": "orgId",
									"value": "{{org_id}}"
								}
							]
						},
						"description": "Delete a pipeline and optionally drop the destination table."
					},
					"response": []
				}
			],
			"description": "Manage pipeline lifecycle"
		},
		{
			"name": "Pipeline Execution",
			"item": [
				{
					"name": "Execute Pipeline",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains run ID\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('data');",
									"    if (jsonData.data.runId) {",
									"        pm.environment.set(\"pipeline_run_id\", jsonData.data.runId);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/run",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"run"
							]
						},
						"description": "Manually trigger pipeline execution."
					},
					"response": []
				},
				{
					"name": "Dry Run Pipeline",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/dry-run",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"dry-run"
							]
						},
						"description": "Test pipeline without writing data to destination."
					},
					"response": []
				},
				{
					"name": "Validate Pipeline",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/validate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"validate"
							]
						},
						"description": "Validate pipeline configuration before execution."
					},
					"response": []
				}
			],
			"description": "Execute and test pipelines"
		},
		{
			"name": "Pipeline Control",
			"item": [
