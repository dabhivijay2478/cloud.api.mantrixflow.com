								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/data-pipelines/{{pipeline_id}}/pause",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"data-pipelines",
								"{{pipeline_id}}",
								"pause"
							]
						},
						"description": "Pause a pipeline to prevent scheduled executions."
					},
					"response": []
				},
				{
					"name": "Resume Pipeline",
					"request": {
